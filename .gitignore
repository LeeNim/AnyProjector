venv/
.venv/
env/
.env/

# --- IDE & Editor ---
.agent/
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter ---
.ipynb_checkpoints/

# --- PyTorch / ML ---
*.pt
*.pth
*.ckpt
*.safetensors
wandb/
runs/
logs/
outputs/

# --- Hugging Face Cache ---
.cache/

# --- Dataset (user-managed, too large for git) ---
dataset/

# --- Misc ---
*.log
*.tmp

